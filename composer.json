{
    "name": "enricodelazzari/wethod-cli",
    "description": "A standalone command-line client for the Wethod API, generated from its OpenAPI spec.",
    "keywords": ["wethod", "cli", "console", "openapi", "laravel zero"],
    "homepage": "https://github.com/enricodelazzari/wethod-cli",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/enricodelazzari/wethod-cli/issues",
        "source": "https://github.com/enricodelazzari/wethod-cli"
    },
    "authors": [
        {
            "name": "Enrico De Lazzari",
            "email": "enricodlz@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "cweagans/composer-patches": "^1.7",
        "illuminate/http": "^12.62",
        "laravel-zero/framework": "^12.0.2",
        "spatie/laravel-openapi-cli": "^1.3",
        "spatie/valuestore": "^1.3"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2",
        "phpacker/phpacker": "^0.6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "cweagans/composer-patches": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "composer-exit-on-patch-failure": true,
        "patches": {
            "spatie/laravel-openapi-cli": {
                "Sanitize multi-line parameter descriptions (upstream PR #9)": "patches/sanitize-multiline-parameter-descriptions.patch"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["wethod"]
}
